# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=acavall_harmony
DB_USER=root
DB_PASSWORD=

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-characters-long
JWT_EXPIRATION=3600
JWT_ISSUER=acavall-harmony

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Application
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# Email Configuration
MAIL_FROM_ADDRESS=noreply@fundacionacavall.com
MAIL_FROM_NAME=Fundación Acavall

# SMTP Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM_NAME=Fundación Acavall
SMTP_FROM_EMAIL=plataforma@fundacionacavall.com

